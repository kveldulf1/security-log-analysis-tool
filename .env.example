# Copy to .env and fill in real values. .env is gitignored — never commit it.
# All values below are placeholders, not real credentials.

# --- CLI authentication (optional; falls back to interactive getpass) ---
SLAT_USERNAME=analyst
SLAT_PASSWORD=change-me

# --- SMTP email alert sink (alerts/email_sink.py) ---
# Use an app password, never your primary account password.
SLAT_SMTP_HOST=smtp.example.com
SLAT_SMTP_PORT=587
SLAT_SMTP_STARTTLS=true
SLAT_SMTP_USERNAME=alerts@example.com
SLAT_SMTP_PASSWORD=change-me
SLAT_SMTP_FROM=alerts@example.com
SLAT_SMTP_TO=soc-team@example.com

# --- Logging ---
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
SLAT_LOG_LEVEL=INFO
